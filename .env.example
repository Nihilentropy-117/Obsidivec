# OpenRouter API Configuration
# Get your API key from https://openrouter.ai

# Required: Your OpenRouter API key
OPENROUTER_API_KEY=your_api_key_here

# Optional: Embedding model to use (default: openai/text-embedding-3-small)
OPENROUTER_MODEL=openai/text-embedding-3-small

# Optional: Number of chunks to process per API request (default: 25)
OPENROUTER_BATCH_SIZE=25

# Optional: Request timeout in seconds (default: 30)
OPENROUTER_TIMEOUT=30
